#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5c30e762b240 .scope module, "tb_and1" "tb_and1" 2 4;
 .timescale -9 -12;
v0x5c30e763db30_0 .var/i "i", 31 0;
v0x5c30e763dc10_0 .var "ta", 0 0;
v0x5c30e763dd00_0 .var "tb", 0 0;
v0x5c30e763de00_0 .net "ty", 0 0, L_0x5c30e763ded0;  1 drivers
S_0x5c30e762b3d0 .scope module, "uut" "and1" 2 10, 3 1 0, S_0x5c30e762b240;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "y";
L_0x5c30e763ded0 .functor AND 1, v0x5c30e763dc10_0, v0x5c30e763dd00_0, C4<1>, C4<1>;
v0x5c30e762b600_0 .net "a", 0 0, v0x5c30e763dc10_0;  1 drivers
v0x5c30e763d950_0 .net "b", 0 0, v0x5c30e763dd00_0;  1 drivers
v0x5c30e763da10_0 .net "y", 0 0, L_0x5c30e763ded0;  alias, 1 drivers
    .scope S_0x5c30e762b240;
T_0 ;
    %vpi_call 2 17 "$monitor", "At time %t: a=%b, b=%b, y=%b", $time, v0x5c30e763dc10_0, v0x5c30e763dd00_0, v0x5c30e763de00_0 {0 0 0};
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5c30e763db30_0, 0, 32;
T_0.0 ;
    %load/vec4 v0x5c30e763db30_0;
    %cmpi/s 4, 0, 32;
    %jmp/0xz T_0.1, 5;
    %load/vec4 v0x5c30e763db30_0;
    %pad/s 2;
    %split/vec4 1;
    %store/vec4 v0x5c30e763dd00_0, 0, 1;
    %store/vec4 v0x5c30e763dc10_0, 0, 1;
    %delay 10000, 0;
    %load/vec4 v0x5c30e763db30_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5c30e763db30_0, 0, 32;
    %jmp T_0.0;
T_0.1 ;
    %vpi_call 2 23 "$stop" {0 0 0};
    %end;
    .thread T_0;
    .scope S_0x5c30e762b240;
T_1 ;
    %vpi_call 2 26 "$dumpfile", "and1.vcd" {0 0 0};
    %vpi_call 2 27 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5c30e762b240 {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "tb_and1.v";
    "and1.v";
